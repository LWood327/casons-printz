# Cason's Printz — environment template
# Copy this file to ".env" and fill in real values.
# The real ".env" is gitignored and must NEVER be committed.
#
# NOTE: For v1 the site is fully static and uses Stripe Payment Links,
# which live directly in products.json (they are public-safe URLs, not
# secret keys). You only need the values below if/when we add a backend
# or the Stripe API later.

# Stripe publishable key (starts with pk_test_ in test mode)
STRIPE_PUBLISHABLE_KEY=

# Stripe secret key (starts with sk_test_) — backend only, keep private
STRIPE_SECRET_KEY=
